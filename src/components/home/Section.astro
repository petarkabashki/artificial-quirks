---
import { cn } from 'astro-pure/utils'

interface Props {
  class?: string
  title: string
  id?: string
}

const { class: className, title, id } = Astro.props
---

<section class={cn('flex flex-col gap-y-5 md:flex-row md:gap-y-0', className)} id={id}>
  <div class='text-xl font-medium md:min-w-36'>
    <h2>{title}</h2>
  </div>
  <div class='flex flex-1 flex-col gap-y-3'>
    <slot />
  </div>
</section>
