---
import { Font } from 'astro:assets'

import { prod } from 'astro-pure/server'
import type { SiteMeta } from 'astro-pure/types'
import site, { activeTheme } from '@/site-config'

type Props = SiteMeta

const { articleDate, description, ogImage, title } = Astro.props

// Read brand from site.config.ts directly (not virtual:config)
const brand = site.title
const delimiter = site.titleDelimiter ?? '·'
const siteTitle = title && title !== brand ? `${title} ${delimiter} ${brand}` : brand
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const socialCard = site.socialCard ?? '/images/social-card.png'
const socialImageURL = new URL(ogImage ? ogImage : socialCard, Astro.url).href
const faviconHref =
  typeof site.favicon === 'string' ? site.favicon : '/favicon/favicon.ico'
---

<meta charset='utf-8' />
<meta content='width=device-width, initial-scale=1.0, shrink-to-fit=no, viewport-fit=cover' name='viewport' />
<meta content='IE=edge' http-equiv='X-UA-Compatible' />
<title>{siteTitle}</title>

{/* Icons / Favicon */}
<link rel='icon' href={faviconHref} />
<link rel='shortcut icon' href={faviconHref} />
<link rel='icon' type='image/png' sizes='32x32' href='/favicon/favicon-32x32.png' />
<link rel='icon' type='image/png' sizes='16x16' href='/favicon/favicon-16x16.png' />
<link rel='apple-touch-icon' sizes='180x180' href='/favicon/apple-touch-icon.png' />
<link rel='manifest' href='/favicon/site.webmanifest' />

{/* Font preloads */}
<Font cssVariable='--font-satoshi' preload={[{ subset: 'latin', style: 'normal' }]} />
<style>
  body {
    font-family: var(--font-satoshi);
  }
</style>

{
  /* [Editorial theme] only ship these fonts when the theme is active — see
  src/assets/styles/themes/editorial.css */
  activeTheme === 'editorial' && (
    <>
      <Font cssVariable='--font-source-serif' preload={[{ subset: 'latin', style: 'normal' }]} />
      <Font cssVariable='--font-inter' preload={[{ subset: 'latin', style: 'normal' }]} />
      <Font cssVariable='--font-plex-mono' preload={[{ subset: 'latin', style: 'normal' }]} />
    </>
  )
}

{/* Canonical URL */}
<link rel='canonical' href={canonicalURL} />

{/* Primary Meta Tags */}
<meta content={siteTitle} name='title' />
<meta content={description} name='description' />
<meta content={site.author} name='author' />

{/* Theme Color */}
{/* <meta content='' name='theme-color' /> */}
<meta name='color-scheme' content='light dark' />

{/* Open Graph / Facebook */}
<meta content={articleDate ? 'article' : 'website'} property='og:type' />
<meta content={title} property='og:title' />
<meta content={description} property='og:description' />
<meta content={canonicalURL} property='og:url' />
<meta content={site.title} property='og:site_name' />
<meta content={site.locale?.attrs ?? 'en_US'} property='og:locale' />
<meta content={socialImageURL} property='og:image' />
<meta content='1200' property='og:image:width' />
<meta content='630' property='og:image:height' />
{
  articleDate && (
    <>
      <meta content={site.author} property='article:author' />
      <meta content={articleDate} property='article:published_time' />
    </>
  )
}

{/* Twitter */}
<meta content='summary_large_image' property='twitter:card' />
<meta content={canonicalURL} property='twitter:url' />
<meta content={title} property='twitter:title' />
<meta content={description} property='twitter:description' />
<meta content={socialImageURL} property='twitter:image' />

{/* Sitemap */}
<link href='/sitemap-index.xml' rel='sitemap' />

{/* RSS auto-discovery */}
<link
  rel='alternate'
  type='application/rss+xml'
  title={site.title}
  href={`${Astro.site}rss.xml`}
/>

<meta content={Astro.generator} name='generator' />

{
  /* User script*/
  prod && (
    <script>
      console.log(
        '%c Artificial Quirks %c https://artificialquirks.com ',
        'color:#fff;background:linear-gradient(90deg,#448bff,#44e9ff);padding:5px 0;',
        'color:#000;background:linear-gradient(90deg,#44e9ff,#ffffff);padding:5px 10px 5px 0px;'
      )
    </script>
  )
}

