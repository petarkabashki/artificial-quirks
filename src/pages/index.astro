---
import { Image } from 'astro:assets'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import MarkdownBody from '@/components/home/MarkdownBody.astro'
import Section from '@/components/home/Section.astro'
import config, { activeTheme } from '@/site-config'
import heroImage from '@/assets/home/hero.jpg'
import smallCellsCover from '../content/blog/rlm-small-cells/cover.jpg'
import historyCompactionCover from '../content/blog/rlm-history-compaction/cover.jpg'
import executionStrategiesCover from '../content/blog/rlm-execution-strategies/cover.jpg'
// Bundle markdown into the build (works on Vercel; no runtime fs)
import siteIntroMd from '../content/home/site-intro.md?raw'

export const prerender = true

const isEditorial = activeTheme === 'editorial'

const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts)
const SHOW_RECENT_THRESHOLD = 6

const topics = [
  {
    title: 'Agent runtimes',
    body: 'Recursive loops, code cells, tool budgets, and the policies that keep long-horizon agents from burning the ledger.',
    href: '/tags/agents'
  },
  {
    title: 'Evaluation & honesty',
    body: 'Measure the deliverable—not only proxy aesthetics. Pair tokens, cells/turn, and step use with FINAL and artefacts.',
    href: '/tags/eval'
  },
  {
    title: 'Strategy over model ifs',
    body: 'Named execution strategies, profile bindings, and task overrides—without hardcoding vendor strings in the engine.',
    href: '/blog/rlm-execution-strategies'
  },
  {
    title: 'Platform & risk',
    body: 'Conversational GenAI, RAG, and enterprise constraints: architecture choices that survive audit and operations.',
    href: '/services'
  }
]

const rlmSeries = [
  {
    href: '/blog/rlm-small-cells',
    title: 'When Smaller Cells Make Agents Worse',
    blurb:
      'Prompt-only “smaller cells” improved aesthetics and missed completion under a short step budget.',
    part: 1,
    image: smallCellsCover
  },
  {
    href: '/blog/rlm-history-compaction',
    title: 'RLM Is Not Automatically Token-Efficient',
    blurb: 'History policy plateaus input tokens; cheaper runs still need deliverable checks.',
    part: 2,
    image: historyCompactionCover
  },
  {
    href: '/blog/rlm-execution-strategies',
    title: 'Strategies, Not Model Ifs',
    blurb: 'Named YAML strategies beat model-id branches in the agent runtime.',
    part: 3,
    image: executionStrategiesCover
  }
]
---

<PageLayout
  meta={{
    title: 'Home',
    description:
      config.description ||
      'Industry notes on agent systems, evaluation, and production GenAI architecture.'
  }}
  highlightColor='#659EB9'
>
  <main class='flex w-full flex-col items-center'>
    <section
      class={cn(
        'animate',
        isEditorial ? 'hero-editorial' : 'mb-10 flex flex-col items-center gap-y-4 text-center'
      )}
      id='content-header'
    >
      <div class={isEditorial ? 'hero-text' : undefined}>
        <!-- <p class='text-sm font-medium uppercase tracking-widest text-muted-foreground'>
          Industry notes · Agent systems · Production GenAI
        </p> -->
        <h1
          class={cn(
            'max-w-2xl text-3xl font-medium sm:text-4xl',
            isEditorial && 'hero-title'
          )}
        >
          {config.title}
        </h1>
        <p class={cn('max-w-xl text-muted-foreground', isEditorial && 'hero-subhead')}>
          {config.description}
        </p>
        <!-- <p class='max-w-lg text-sm text-muted-foreground'>
          For architects and platform leads shipping agents under cost, evaluation, and operational
          constraints—quirks included.
        </p> -->
        <div class={cn('mt-2 flex flex-wrap gap-3', !isEditorial && 'justify-center')}>
          <Button
            title='Start with the RLM series'
            href='#current-series'
            variant='ahead'
            class={isEditorial ? 'cta-solid' : undefined}
          />
          <Button
            title='Services'
            href='/services'
            variant='back'
            class={isEditorial ? 'cta-outline' : undefined}
          />
        </div>
      </div>
      {
        isEditorial && (
          <div class='hero-image-slot'>
            <Image src={heroImage} alt='' loading='eager' />
          </div>
        )
      }
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='This site' class={isEditorial ? 'section-divider' : undefined}>
        <div
          class={cn(
            'max-w-none text-muted-foreground',
            config.integ.typography.class,
            'prose-headings:text-foreground prose-a:text-foreground'
          )}
        >
          <MarkdownBody raw={siteIntroMd} />
        </div>
      </Section>

      <Section
        title='Current series'
        class={cn('scroll-mt-24', isEditorial && 'section-divider')}
        id='current-series'
      >
        <p class='text-sm text-muted-foreground'>
          Recursive language-model loops: three notes on cells, history, and named strategies.
        </p>
        <ol class={cn('flex flex-col text-muted-foreground', isEditorial ? 'series-list' : 'gap-y-4')}>
          {
            rlmSeries.map((item) => (
              <li class={isEditorial ? 'series-row' : 'flex gap-x-3'}>
                <span
                  class={cn(
                    'mt-0.5 flex shrink-0 items-center text-xs font-medium text-foreground',
                    isEditorial
                      ? 'series-index'
                      : 'size-7 justify-center rounded-full border'
                  )}
                >
                  {item.part}
                </span>
                <div>
                  <a class='font-medium text-foreground hover:underline' href={item.href}>
                    {item.title}
                  </a>
                  <p class='text-sm'>{item.blurb}</p>
                </div>
                {isEditorial && (
                  <div class='series-thumb' aria-hidden='true'>
                    <Image src={item.image} alt='' loading='lazy' />
                  </div>
                )}
              </li>
            ))
          }
        </ol>
        <Button title='All posts' class='w-fit self-end' href='/blog' variant='ahead' />
      </Section>

      <Section title='Topics' class={isEditorial ? 'section-divider' : undefined}>
        <ul
          class={cn(
            'grid grid-cols-1 sm:grid-cols-2',
            isEditorial ? 'topics-grid' : 'gap-4'
          )}
        >
          {
            topics.map((t) => (
              <li>
                <a
                  href={t.href}
                  class={cn(
                    'block h-full transition-colors',
                    isEditorial
                      ? 'topics-cell hover:bg-muted'
                      : 'rounded-xl border bg-background/60 p-4 hover:border-foreground/25 hover:bg-background'
                  )}
                >
                  <h3 class='font-medium text-foreground'>{t.title}</h3>
                  <p class='mt-1 text-sm text-muted-foreground'>{t.body}</p>
                </a>
              </li>
            ))
          }
        </ul>
      </Section>

      {
        isEditorial ? (
          <section class='work-panel'>
            <div>
              <h2>Work with us</h2>
              <p class='text-muted-foreground'>
                Optional advisory: agent runtime reviews, evaluation design, and GenAI platform
                architecture under real operational constraints.
              </p>
            </div>
            <div class='flex flex-wrap gap-3'>
              <Button title='View services' href='/services' variant='ahead' class='cta-solid' />
              <Button title='About the author' href='/about' variant='back' class='cta-outline' />
            </div>
          </section>
        ) : (
          <Section title='Work with us'>
            <p class='text-muted-foreground'>
              Optional advisory: agent runtime reviews, evaluation design, and GenAI platform
              architecture under real operational constraints.
            </p>
            <div class='flex flex-wrap gap-3'>
              <Button title='View services' href='/services' variant='ahead' />
              <Button title='About the author' href='/about' variant='back' />
            </div>
          </Section>
        )
      }

      {
        allPostsByDate.length >= SHOW_RECENT_THRESHOLD && (
          <Section title='Recent posts' class={isEditorial ? 'section-divider' : undefined}>
            <ul
              class={cn(
                'flex flex-col text-muted-foreground',
                isEditorial ? 'series-list' : 'gap-y-3'
              )}
            >
              {allPostsByDate.slice(0, 8).map((p) => (
                <li>
                  <div>
                    <a
                      class='font-medium text-foreground hover:underline'
                      href={`/blog/${p.id}`}
                    >
                      {p.data.title}
                    </a>
                    <p class='text-sm'>{p.data.description}</p>
                  </div>
                </li>
              ))}
            </ul>
            <Button
              title='Blog archive'
              class={cn('w-fit self-end', isEditorial && 'cta-solid')}
              href='/blog'
              variant='ahead'
            />
          </Section>
        )
      }
    </div>
  </main>
</PageLayout>
