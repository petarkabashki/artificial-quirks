---
import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import MarkdownFile from '@/components/home/MarkdownFile.astro'
import Section from '@/components/home/Section.astro'
import config from '@/site-config'

export const prerender = true

const MAX_POSTS = 8
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const topics = [
  {
    title: 'Agent runtimes',
    body: 'Recursive loops, code cells, tool budgets, and the policies that keep long-horizon agents from burning the ledger.'
  },
  {
    title: 'Evaluation & honesty',
    body: 'Measure the deliverable—not only proxy aesthetics. Pair tokens, cells/turn, and step use with FINAL and artefacts.'
  },
  {
    title: 'Strategy over model ifs',
    body: 'Named execution strategies, profile bindings, and task overrides—without hardcoding vendor strings in the engine.'
  },
  {
    title: 'Platform & risk',
    body: 'Conversational GenAI, RAG, and enterprise constraints: architecture choices that survive audit and operations.'
  }
]

const featuredWriting = [
  {
    href: '/blog/rlm-small-cells',
    title: 'When Smaller Cells Make Agents Worse',
    blurb:
      'Prompt-only “smaller cells” improved aesthetics and missed completion under a short step budget.'
  },
  {
    href: '/blog/rlm-history-compaction',
    title: 'RLM Is Not Automatically Token-Efficient',
    blurb: 'History policy plateaus input tokens; cheaper runs still need deliverable checks.'
  },
  {
    href: '/blog/rlm-execution-strategies',
    title: 'Strategies, Not Model Ifs',
    blurb: 'Named YAML strategies beat model-id branches in the agent runtime.'
  }
]
---

<PageLayout
  meta={{
    title: 'Home',
    description:
      config.description ||
      'Industry notes on agent systems, evaluation, and production GenAI architecture.'
  }}
  highlightColor='#659EB9'
>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-4 text-center' id='content-header'>
      <p class='text-sm font-medium uppercase tracking-widest text-muted-foreground'>
        artificialquirks.com
      </p>
      <h1 class='max-w-2xl text-3xl font-medium sm:text-4xl'>{config.title}</h1>
      <p class='max-w-xl text-muted-foreground'>
        {config.description}
      </p>
      <div class='mt-2 flex flex-wrap justify-center gap-3'>
        <Button title='Read the blog' href='/blog' variant='ahead' />
        <Button title='About the author' href='/about' variant='back' />
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='This site'>
        <div
          class={cn(
            'max-w-none text-muted-foreground',
            config.integ.typography.class,
            'prose-headings:text-foreground prose-a:text-foreground'
          )}
        >
          <MarkdownFile src='content/home/site-intro.md' />
        </div>
      </Section>

      <Section title='Topics'>
        <ul class='grid grid-cols-1 gap-4 sm:grid-cols-2'>
          {
            topics.map((t) => (
              <li class='rounded-xl border bg-background/60 p-4'>
                <h3 class='font-medium text-foreground'>{t.title}</h3>
                <p class='mt-1 text-sm text-muted-foreground'>{t.body}</p>
              </li>
            ))
          }
        </ul>
      </Section>

      <Section title='Featured writing'>
        <ul class='flex flex-col gap-y-3 text-muted-foreground'>
          {
            featuredWriting.map((item) => (
              <li>
                <a class='font-medium text-foreground hover:underline' href={item.href}>
                  {item.title}
                </a>
                <p class='text-sm'>{item.blurb}</p>
              </li>
            ))
          }
        </ul>
        <Button title='All posts' class='w-fit self-end' href='/blog' variant='ahead' />
      </Section>

      {
        allPostsByDate.length > 0 && (
          <Section title='Recent posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='Blog archive' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>
